# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=civicportal
DB_ROOT_PASSWORD=changeme        # MySQL root password — change before production
# DB_USER is always root in this setup; override here if using a non-root account

# ── Face Service ──────────────────────────────────────────────────────────────
FACE_SERVICE_PORT=5001           # Internal port face-service listens on
# FACE_SERVICE_URL is derived automatically in docker-compose; set manually only
# when running web outside Docker: FACE_SERVICE_URL=http://localhost:5001

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=8080                    # Host port mapped to Apache (http://localhost:8080)
APP_ENV=development              # Set to "production" to enable HTTPS-only cookies

# ── API Keys ──────────────────────────────────────────────────────────────────
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GEMINI_API_KEY=
